    {
      "parameters": {
        "content": "## Workflow of each node \nNode 1: Manual Trigger\n  Starts the workflow\n  ↓ passes: nothing (just a trigger)\n\nNode 2: Customer Email Data\n  Sets the customer information\n  ↓ passes: name, email, subject, message\n\nNode 3: AI Agent\n  Reads the customer message and drafts a reply\n  ↓ passes: ai output (the drafted email text)\n\nNode 4: Format Review Data\n  Combines AI draft + original customer details\n  ↓ passes: ai_draft + name + email + subject + query\n\nNode 5: Send Review Email\n  Emails the manager with draft + approve/reject links\n  ↓ passes: same data package (unchanged)\n\nNode 6: WAIT — workflow completely pauses here\n  ↓ nothing moves until manager clicks a link\n  ↓ passes: original data + action (approve/reject)\n\nNode 7: IF Check Decision\n  Reads the action parameter\n  ↓ TRUE (approve) → Node 8A\n  ↓ FALSE (reject) → Node 8B\n\nNode 8A: Send Email to Customer\n  Delivers the approved draft to the customer\n  ↓ passes: sent email confirmation\n\nNode 8B: Log Rejection\n  Records that draft was rejected\n  ↓ passes: rejection status\n\nNode 9: Postgres Log\n  Saves the decision permanently to database\n  ↓ end of workflow\n",
        "height": 672,
        "width": 448
      },
      "type": "n8n-nodes-base.stickyNote",
      "position": [
        -3040,
        432
      ],
      "typeVersion": 1,
      "id": "bda5cb98-10e2-4d7b-a057-cb07340b5a02",
      "name": "Sticky Note"
    },
    {
      "parameters": {
        "sendTo": "sanikashinde992@gmail.com",
        "subject": "=ACTION REQUIRED — Review AI Draft for {{ $('Format Review Data').item.json.customer_name }}",
        "message": "=<!DOCTYPE html>\n<html>\n<head>\n<style>\n  body { font-family: Arial, sans-serif; background: #f5f5f5; padding: 20px; }\n  .container { background: white; max-width: 600px; margin: auto; border-radius: 10px; padding: 30px; border: 1px solid #ddd; }\n  h2 { color: #333; border-bottom: 2px solid #eee; padding-bottom: 10px; }\n  .label { font-weight: bold; color: #555; }\n  .draft-box { background: #f9f9f9; border-left: 4px solid #007bff; padding: 15px; margin: 15px 0; border-radius: 4px; white-space: pre-wrap; font-size: 14px; }\n  .buttons { margin-top: 25px; text-align: center; }\n  .btn { display: inline-block; padding: 14px 24px; margin: 8px; border-radius: 6px; font-size: 15px; font-weight: bold; text-decoration: none; color: white; }\n  .approve { background-color: #28a745; }\n  .reject  { background-color: #dc3545; }\n  .edit    { background-color: #f59e0b; }\n  .warning { color: #856404; background: #fff3cd; padding: 10px; border-radius: 4px; margin-top: 20px; font-size: 13px; text-align: center; }\n</style>\n</head>\n<body>\n<div class=\"container\">\n  <h2>📧 Email Approval Request</h2>\n\n  <p><span class=\"label\">Customer Name:</span> {{ $('Format Review Data').item.json.customer_name }}</p>\n  <p><span class=\"label\">Customer Email:</span> {{ $('Format Review Data').item.json.customer_email }}</p>\n  <p><span class=\"label\">Subject:</span> {{ $('Format Review Data').item.json.subject }}</p>\n  <p><span class=\"label\">Original Query:</span> {{ $('Format Review Data').item.json.original_query }}</p>\n\n  <p><span class=\"label\">AI Drafted Reply:</span></p>\n  <div class=\"draft-box\">{{ $('Format Review Data').item.json.ai_draft }}</div>\n\n  <div class=\"buttons\">\n    <a class=\"btn approve\" href=\"{{ $execution.resumeUrl }}?decision=approved\">\n      ✅ Approve — Send to Customer\n    </a>\n    <a class=\"btn reject\" href=\"{{ $execution.resumeUrl }}?decision=rejected\">\n      ❌ Reject — Do Not Send\n    </a>\n    <a class=\"btn edit\" href=\"{{ $execution.resumeUrl }}\">\n      ✏️ Edit &amp; Revise\n    </a>\n  </div>\n\n  <div class=\"warning\">\n    ⚠️ This approval link expires in 24 hours. Please click one button above.\n  </div>\n</div>\n</body>\n</html>",
        "options": {}
