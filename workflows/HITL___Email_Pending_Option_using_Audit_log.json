      "parameters": {
        "html": "<!DOCTYPE html>\n<html>\n<head>\n  <style>\n    body { font-family: Arial, sans-serif; background: #f5f5f5; padding: 20px; }\n    .container { background: white; max-width: 600px; margin: auto; border-radius: 10px; padding: 30px; border: 1px solid #ddd; }\n    h2 { color: #333; border-bottom: 2px solid #eee; padding-bottom: 10px; }\n    .label { font-weight: bold; color: #555; }\n    .draft-box { background: #f9f9f9; border-left: 4px solid #007bff; padding: 15px; margin: 15px 0; border-radius: 4px; white-space: pre-wrap; font-size: 14px; }\n    .buttons { margin-top: 25px; display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; }\n    .btn-link { display: inline-block; padding: 14px 24px; border-radius: 6px; font-size: 15px; font-weight: bold; text-decoration: none; color: white !important; text-align: center; cursor: pointer; border: none; }\n    .approve { background-color: #28a745; }\n    .approve:hover { background-color: #218838; }\n    .reject { background-color: #dc3545; }\n    .reject:hover { background-color: #c82333; }\n    .pending { background-color: #6c757d; }\n    .pending:hover { background-color: #5a6268; }\n    .edit-btn { background-color: #f59e0b; color: white !important; }\n    .edit-btn:hover { background-color: #d97706; }\n    #editSection {\n      display: none;\n      margin-top: 24px;\n      background: #fffbea;\n      border: 1px solid #f59e0b;\n      border-radius: 8px;\n      padding: 20px;\n    }\n    .warning { color: #856404; background: #fff3cd; padding: 10px; border-radius: 4px; margin-top: 20px; font-size: 13px; text-align: center; }\n  </style>\n</head>\n<body>\n<div class=\"container\">\n  <h2>📧 Email Approval Request</h2>\n  <p><span class=\"label\">Customer Name:</span> {{ $json.customer_name }}</p>\n  <p><span class=\"label\">Customer Email:</span> {{ $json.customer_email }}</p>\n  <p><span class=\"label\">Subject:</span> {{ $json.subject }}</p>\n  <p><span class=\"label\">Original Query:</span> {{ $json.original_query }}</p>\n  <p><span class=\"label\">AI Drafted Reply:</span></p>\n  <div class=\"draft-box\">{{ $json.ai_draft }}</div>\n\n  <!-- ALL 4 BUTTONS -->\n  <div class=\"buttons\">\n    <a class=\"btn-link approve\" href=\"{{ $execution.resumeUrl }}?decision=approved\">\n      ✅ Approve — Send to Customer\n    </a>\n    <a class=\"btn-link reject\" href=\"{{ $execution.resumeUrl }}?decision=rejected\">\n      ❌ Reject — Do Not Send\n    </a>\n    <a class=\"btn-link pending\" href=\"{{ $execution.resumeUrl }}?decision=pending\">\n      ⏳ Pending — Review Later\n    </a>\n\n  </div>\n\n  <!-- EDIT SECTION (only textarea + submit, no heading text) -->\n  <div id=\"editSection\">\n    <form method=\"POST\" action=\"{{ $execution.resumeUrl }}?decision=edited\">\n      <textarea\n        name=\"editedContent\"\n        style=\"width:100%; height:160px; padding:12px; border:1px solid #ccc; border-radius:6px; font-size:14px; font-family:Arial; resize:vertical; box-sizing:border-box;\"\n      >{{ $json.ai_draft }}</textarea>\n      <br/>\n      <button\n        type=\"submit\"\n        style=\"margin-top:12px; background-color:#3b82f6; color:white; padding:12px 24px; border:none; border-radius:6px; font-size:15px; font-weight:bold; cursor:pointer; width:100%;\"\n      >\n        📨 Submit\n      </button>\n    </form>\n  </div>\n\n  <div class=\"warning\">\n    ⚠️ This approval link expires in 24 hours. Please click one button above.\n  </div>\n</div>\n\n<script>\n  function toggleEdit() {\n    var section = document.getElementById('editSection');\n    section.style.display = (section.style.display === 'block') ? 'none' : 'block';\n  }\n</script>\n</body>\n</html>"
