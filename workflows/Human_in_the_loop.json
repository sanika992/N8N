      "parameters": {
        "html": "<!DOCTYPE html>\n<html>\n<head>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      background: #f5f5f5;\n      padding: 20px;\n    }\n\n    .container {\n      background: white;\n      max-width: 700px;\n      margin: auto;\n      padding: 30px;\n      border-radius: 10px;\n      border: 1px solid #ddd;\n    }\n\n    h2 {\n      color: #333;\n      border-bottom: 2px solid #eee;\n      padding-bottom: 10px;\n    }\n\n    .label {\n      font-weight: bold;\n      color: #555;\n    }\n\n    .draft-box {\n      background: #f8f9fa;\n      border-left: 4px solid #007bff;\n      padding: 15px;\n      margin-top: 10px;\n      white-space: pre-wrap;\n      border-radius: 5px;\n    }\n\n    .buttons {\n      margin-top: 25px;\n      display: flex;\n      flex-wrap: wrap;\n      gap: 10px;\n      justify-content: center;\n    }\n\n    .btn-link {\n      display: inline-block;\n      padding: 14px 22px;\n      text-decoration: none;\n      color: white !important;\n      border-radius: 6px;\n      font-weight: bold;\n    }\n\n    .approve {\n      background: #28a745;\n    }\n\n    .reject {\n      background: #dc3545;\n    }\n\n    .edit-btn {\n      background: #f59e0b;\n    }\n\n    #editSection {\n      display: none;\n      margin-top: 20px;\n      border: 1px solid #f59e0b;\n      padding: 20px;\n      border-radius: 8px;\n      background: #fffbea;\n    }\n\n    .warning {\n      margin-top: 20px;\n      background: #fff3cd;\n      padding: 10px;\n      border-radius: 4px;\n      text-align: center;\n      font-size: 13px;\n    }\n  </style>\n</head>\n\n<body>\n\n<div class=\"container\">\n\n<h2>📧 Welcome Email Approval Request</h2>\n\n<p>\n<span class=\"label\">Employee Name:</span>\n{{ $json.employee_name }}\n</p>\n\n<p>\n<span class=\"label\">Employee Email:</span>\n{{ $json.employee_email }}\n</p>\n\n<p>\n<span class=\"label\">Department:</span>\n{{ $json.department }}\n</p>\n\n<p>\n<span class=\"label\">AI Generated Welcome Email:</span>\n</p>\n\n<div class=\"draft-box\">\n{{ $json.ai_draft }}\n</div>\n\n<div class=\"buttons\">\n\n<a class=\"btn-link approve\"\nhref=\"{{ $execution.resumeUrl }}?decision=approved\">\n✅ Approve & Send\n</a>\n\n<a class=\"btn-link reject\"\nhref=\"{{ $execution.resumeUrl }}?decision=rejected\">\n❌ Reject\n</a>\n\n<a class=\"btn-link edit-btn\"\nhref=\"javascript:void(0)\"\nonclick=\"toggleEdit()\">\n✏ Edit & Approve\n</a>\n\n</div>\n\n<div id=\"editSection\">\n\n<form method=\"POST\"\naction=\"{{ $execution.resumeUrl }}?decision=edited\">\n\n<textarea\nname=\"editedContent\"\nstyle=\"width:100%;\nheight:180px;\npadding:10px;\nfont-size:14px;\nborder-radius:6px;\">\n{{ $json.ai_draft }}\n</textarea>\n\n<br><br>\n\n<button type=\"submit\"\nstyle=\"\nbackground:#007bff;\ncolor:white;\nborder:none;\npadding:12px 24px;\nborder-radius:6px;\ncursor:pointer;\nwidth:100%;\">\n📨 Submit Edited Version\n</button>\n\n</form>\n\n</div>\n\n<div class=\"warning\">\n⚠ Manager approval is required before the email is sent to the employee.\n</div>\n\n</div>\n\n<script>\n\nfunction toggleEdit() {\n\nvar section =\ndocument.getElementById('editSection');\n\nsection.style.display =\n(section.style.display === 'block')\n? 'none'\n: 'block';\n\n}\n\n</script>\n\n</body>\n</html>"
